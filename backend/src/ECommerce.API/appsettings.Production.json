{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Migrations": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:80"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8081",
      "http://localhost:19006"
    ]
  },
  "Jwt": {
    "Issuer": "ECommerce.Identity",
    "Audience": "ECommerce.Client",
    "AccessTokenMinutes": 15,
    "RefreshTokenDaysWeb": 7,
    "RefreshTokenDaysMobile": 30
  },
  "Iyzico": {
    "BaseUrl": "https://sandbox-api.iyzipay.com"
  },
  "Smtp": {
    "Port": 587,
    "FromEmail": "no-reply@vbt-commerce.test",
    "FromName": "VBT-Commerce",
    "UseSsl": true
  },
  "PasswordReset": {
    "TokenExpiryMinutes": 30
  },
  "Frontend": {
    "PasswordResetUrl": "https://intern-api.kayas.dev/reset-password"
  }
}
